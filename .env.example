# TinaCMS Configuration
# Get these values from your TinaCMS project at app.tina.io

NEXT_PUBLIC_TINA_CLIENT_ID=your_client_id_here
TINA_TOKEN=your_token_here
NEXT_PUBLIC_TINA_BRANCH=main

# Optional: For development with local authentication
# NEXT_PUBLIC_TINA_API_URL=http://localhost:4001/graphql

# For GitHub Pages deployment, add these as repository secrets:
# - NEXT_PUBLIC_TINA_CLIENT_ID
# - TINA_TOKEN